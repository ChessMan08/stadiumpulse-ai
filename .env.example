# LLM provider: "gemini" or "mock". Falls back to "mock" automatically if
# GEMINI_API_KEY is empty, so the app never crashes without a key.
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001

# Shared secret required on staff-only endpoints (ops copilot, workforce
# scheduler). Change this before a real deployment.
OPS_API_KEY=DEMO-OPS-KEY-2026

# Comma-separated list of allowed CORS origins, or "*" for any.
ALLOWED_ORIGINS=*

ENV=development
